---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section
      id="experience"
      class="p-8 sm:p-12 md:p-16 lg:p-24 bg-slate-950 text-slate-50 scroll-mt-24"
      style={`--accent-color: ${siteConfig.accentColor}`}
    >
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-slate-50">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <p class="mb-8 text-sm sm:text-base text-slate-300">
              Over 2+ years of hands‑on experience as a Data, Business, and Product Analytics intern, working across pipelines,
              dashboards, and stakeholder‑facing insights.
            </p>
            <div class="relative">
              {siteConfig.experience.map((exp, index) => (
                <div class="relative mb-12 last:mb-0">
                  {/* Timeline dot at top of card */}
                  <div
                    class="absolute left-1/2 -top-2 w-4 h-4 bg-slate-950 border-2 rounded-full -translate-x-1/2 z-20 transition-all duration-300"
                    style={`border-color: ${siteConfig.accentColor}; background-color: ${siteConfig.accentColor}`}
                  />

                  {/* Connecting line below card */}
                  {index < siteConfig.experience.length - 1 && (
                    <div class="absolute left-1/2 bottom-0 w-0.5 h-12 bg-slate-700 -translate-x-1/2 translate-y-full z-10" />
                  )}

                  {/* Experience card */}
                  <div class="bg-slate-900 rounded-lg shadow-sm border border-slate-800 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4">
                      <div class="flex items-center gap-3">
                        <div class="relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-full bg-slate-800 border border-slate-700">
                          {exp.logoUrl ? (
                            <img
                              src={exp.logoUrl}
                              alt={exp.company}
                              class="h-full w-full object-cover"
                              loading="lazy"
                            />
                          ) : (
                            <span class="text-xs font-semibold text-slate-100">
                              {exp.company
                                .split(" ")
                                .map((part) => part[0])
                                .join("")}
                            </span>
                          )}
                        </div>
                        <div>
                          <h3 class="text-lg sm:text-xl font-semibold text-slate-50">
                            {exp.title}
                          </h3>
                          <p
                            class="text-base sm:text-lg"
                            style={`color: ${siteConfig.accentColor}`}
                          >
                            {exp.company}
                          </p>
                        </div>
                      </div>
                      <span class="text-xs sm:text-sm text-slate-400 mt-3 sm:mt-0">
                        {exp.dateRange}
                      </span>
                    </div>

                    <ul class="space-y-2">
                      {exp.bullets.map((bullet) => {
                        const metricRegex = /(\d+(?:\.\d+)?%|\d+\s?k\+|\d+,\d+\+|\d+\+|\d+,\d+)/g;
                        const metricTest = /^(?:\d+(?:\.\d+)?%|\d+\s?k\+|\d+,\d+\+|\d+\+|\d+,\d+)$/;
                        const parts = bullet.split(metricRegex);
                        return (
                          <li class="flex items-start">
                            <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--accent-color)]/70 mt-2 mr-3 flex-shrink-0" />
                            <span class="text-sm sm:text-base text-slate-200">
                              {parts.map((part, idx) =>
                                metricTest.test(part) ? (
                                  <span
                                    key={idx}
                                    class="font-semibold text-[var(--accent-color)]"
                                  >
                                    {part}
                                  </span>
                                ) : (
                                  <span key={idx}>{part}</span>
                                ),
                              )}
                            </span>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
